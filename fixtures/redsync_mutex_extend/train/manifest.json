{
  "task_id": "redsync_mutex_extend_train",
  "family": "redsync_mutex_extend",
  "split": "train",
  "description": "Real-world external artifact bundle derived from go-redsync/redsync. The target invariant is the mutex-extend window rule: Extend is legal only while the lock window is still active; expired or closed locks must not extend successfully.",
  "roles": {
    "acquire": "LOCK",
    "release": "UNLOCK",
    "extend": "EXTEND"
  },
  "canonical_roles": {
    "acquire": "open",
    "release": "close",
    "extend": "write"
  },
  "natural_language_spec": "LOCK opens a mutex ownership window. EXTEND is legal only while that window is still active. UNLOCK closes the window. After expiry or release, EXTEND must fail.",
  "formal_spec": {
    "rules": [
      "LOCK -> mutex_live",
      "EXTEND -> mutex_live",
      "UNLOCK -> previously mutex_live",
      "trace_end -> not mutex_live"
    ],
    "safety_property": "No EXTEND occurs after the lock has expired or after the lock window has been closed."
  },
