  "natural_language_spec": "etcd Raft follows the paper rule that a leader only commits entries from its current term by counting replicas. A prior-term log tail may still be present after leadership changes, but advancing commit requires quorum evidence and the presence of a current-term entry.",
  "formal_spec": {
    "rules": [
      "PRIOR_TERM_LOG -> BECOME_LEADER",
      "ADVANCE_COMMIT_INDEX -> BECOME_LEADER",
      "ADVANCE_COMMIT_INDEX -> QUORUM_MATCH",
      "ADVANCE_COMMIT_INDEX -> CURRENT_TERM_ENTRY",
      "ADVANCE_COMMIT_INDEX -> two REPLICA_MATCH signals"
    ],
    "safety_property": "A leader must not advance commit on quorum replicas alone when the highest committed entry is still from a previous term."
  },
