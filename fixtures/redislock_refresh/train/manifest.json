{
  "task_id": "redislock_refresh_train",
  "family": "redislock_refresh",
  "split": "train",
  "description": "Real-world external artifact bundle derived from bsm/redislock. The target invariant is the lock-refresh window rule: Refresh is legal only while the lock is still held; expired or released locks must not refresh successfully.",
  "roles": {
    "obtain": "OBTAIN",
    "release": "RELEASE",
    "refresh": "REFRESH"
  },
  "canonical_roles": {
    "obtain": "open",
    "release": "close",
    "refresh": "write"
  },
  "natural_language_spec": "OBTAIN opens a lock ownership window. REFRESH is legal only while that lock is still held. RELEASE closes the window. After expiry or release, REFRESH must fail.",
  "formal_spec": {
    "rules": [
      "OBTAIN -> lock_live",
      "REFRESH -> lock_live",
      "RELEASE -> previously lock_live",
      "trace_end -> not lock_live"
    ],
    "safety_property": "No REFRESH occurs after the lock has expired or after the lock has been released."
  },
