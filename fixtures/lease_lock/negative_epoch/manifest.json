    "acquire": "open",
    "release": "close",
    "mutate": "write",
    "epoch": "epoch"
  },
  "natural_language_spec": "ACQUIRE opens a lease window. MUTATE is legal only while the lease is live and the current epoch is valid. RELEASE closes the lease. A valid mutation requires a prior EPOCH marker inside the lease.",
  "formal_spec": {
    "rules": [
      "ACQUIRE -> lease_live",
      "MUTATE -> lease_live",
      "MUTATE -> EPOCH",
      "RELEASE -> previously lease_live",
      "trace_end -> not lease_live"
    ],
    "safety_property": "No MUTATE occurs while the lease is inactive or before the current epoch is established."
  },
