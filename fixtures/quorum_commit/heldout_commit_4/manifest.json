    "rules": [
      "PENDING -> PREPARE",
      "COMMIT -> CLEAR",
      "COMMIT -> ACK_1",
      "COMMIT -> ACK_2",
      "COMMIT xor PENDING"
    ],
    "safety_property": "No COMMIT occurs before two acknowledgements and the clear condition are satisfied."
