# Copy this file to `.env` or set these variables directly in your shell.
# Never commit real keys.

# Required for live Groq-backed proposal paths.
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides.
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional alternative OpenAI-compatible backend.
OPENAI_API_KEY=
